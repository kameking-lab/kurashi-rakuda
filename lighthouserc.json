{
  "$comment": "Lighthouse CI バジェット（docs/04 UI十原則: LCP 2.0s以内・CLSほぼゼロ・Performance/Accessibility 90以上）。LCP のエラー閾値は CI 環境の揺らぎを考慮して 2500ms（Google の good 境界）。計測対象に最重量2ページ（money/sankyu-ikukyu-money・childcare/hoikuryo）を追加した（診断 B-4、O-1 バンドル分割マージ後に有効化）。★S-2（ツール詳細バンドル肥大）の真の検出信号は script のバイト量★。CI/localhost では巨大バンドルも即ダウンロードされ LCP に出ないため（例: 分割前 1.03MB でも chomiryo は緑だった）、resource-summary:script:size をツール詳細ページに課してバンドル再肥大を機械検出する。hoikuryo の LCP は 147自治体の出典一覧（SSR HTML）が支配的でバンドル起因ではないため warn 扱いにし、CLS と script:size は厳格に保つ。",
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/tools",
        "http://localhost:3000/tools/kaji/chomiryo-kanzan",
        "http://localhost:3000/tools/money/sankyu-ikukyu-money",
        "http://localhost:3000/tools/childcare/hoikuryo"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": ["warn", { "minScore": 0.9 }],
            "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
            "total-blocking-time": ["warn", { "maxNumericValue": 300 }]
          }
        },
        {
          "matchingUrlPattern": "^(?!.*hoikuryo).*$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.9 }],
            "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }]
          }
        },
        {
          "matchingUrlPattern": ".*hoikuryo.*",
          "assertions": {
            "categories:performance": ["warn", { "minScore": 0.9 }],
            "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }]
          }
        },
        {
          "matchingUrlPattern": ".*/tools/[^/]+/[^/]+.*",
          "assertions": {
            "resource-summary:script:size": ["error", { "maxNumericValue": 350000 }]
          }
        }
      ]
    }
  }
}
