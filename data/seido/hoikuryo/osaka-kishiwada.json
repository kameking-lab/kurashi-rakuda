  "amendments": [
    {
      "summary": "令和8年度版の利用者負担額表を自治体公式サイトで確認できないため、令和7年度版を継続収録する。",
      "status": "under-review",
      "sourceId": "kishiwada-r7",
      "impact": "令和8年度の試算では参考値として表示し、令和8年度版の公表を確認次第、階層・金額・軽減条件を再検証して差し替える。"
    }
  ],
  "disclaimer": "本データは大阪府岸和田市の自治体公式資料に基づく参考情報です。実際の保育料は税額、世帯状況、きょうだい構成等により自治体が決定するため、決定通知書または担当窓口で確認してください。",
  "scope": {
    "includes": [
      "認可保育所・認定こども園等の一般世帯・第1子の月額保育料"
    ],
    "excludes": [
      "ひとり親・障害者同居世帯等の軽減後金額",
      "第2子以降の軽減後金額",
      "延長保育料",
      "給食費・副食費・行事費等の実費"
    ]
  },
  "bracketBasis": {
    "basis": "市町村民税所得割額",
    "taxYearRule": "4～8月は前年度、9月～翌3月は当年度の市町村民税額を基礎に算定。",
    "note": "児童と同住所の世帯員（主に父母）の市民税額を合算。寄附金・配当・外国税額・住宅借入金・配当割・株式等譲渡所得割の各控除前。6/8換算は一次情報で確認できず未確認。R8版未公表のためR7表を収録。"
  },
