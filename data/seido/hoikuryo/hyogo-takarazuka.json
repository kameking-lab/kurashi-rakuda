  "amendments": [
    {
      "summary": "令和8年度版の利用者負担額表を自治体公式サイトで確認できないため、令和7年度版を継続収録する。2026-07-20に再確認したが状況変わらず未公表。",
      "status": "under-review",
      "sourceId": "takarazuka-r7",
      "impact": "令和8年度の試算では参考値として表示し、令和8年度版の公表を確認次第、階層・金額・軽減条件を再検証して差し替える。"
    }
  ],
  "disclaimer": "本データは兵庫県宝塚市の自治体公式資料に基づく参考情報です。実際の保育料は税額、世帯状況、きょうだい構成等により自治体が決定するため、決定通知書または担当窓口で確認してください。",
  "scope": {
    "includes": [
      "認可保育所・認定こども園等の一般世帯・第1子の月額保育料"
    ],
    "excludes": [
      "ひとり親・障害者同居世帯等の軽減後金額",
      "第2子以降の軽減後金額",
      "延長保育料",
      "給食費・副食費・行事費等の実費"
    ]
  },
  "bracketBasis": {
    "basis": "市町村民税所得割額",
    "taxYearRule": "4～8月は前年度、9月～翌3月は当年度の市町村民税額を基礎に算定。",
    "note": "R7年9月～R8年8月はR7年度税、R8年9月～R9年8月はR8年度税。所得割は調整控除のみ適用し、寄附金・住宅借入金・配当等は控除前。6/8換算は未確認。R8年度表自体は未公表のためR7表を収録。"
  },
