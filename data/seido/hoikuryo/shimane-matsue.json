  "bracketBasis": {
    "basis": "市町村民税所得割額",
    "householdScope": "父母の市町村民税額を合算。父母の年間収入合計が120万円未満かつ祖父母等が児童の健康保険扶養者の場合は当該扶養者も算入。",
    "taxYearRule": "4～8月は前年度、9月～翌3月は当年度の市町村民税所得割額",
    "deductionsIgnored": [
      "寄附金税額控除",
      "外国税額控除",
      "配当割額・株式等譲渡所得割額控除",
