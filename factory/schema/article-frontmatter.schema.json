{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "factory/schema/article-frontmatter.schema.json",
  "title": "くらしのラクダ 記事フロントマター",
  "type": "object",
  "required": ["id", "title", "type", "category", "sources", "last_updated"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "type": { "type": "string", "enum": ["seido-kaisetsu", "tool-narisou", "dandori"] },
    "category": {
      "type": "string",
      "enum": ["妊娠・出産", "子育て", "家事・料理", "お金", "健康・美容", "仕事・キャリア", "介護"]
    },
    "tool_ref": { "type": ["string", "null"] },
    "persona": { "type": "string" },
    "revision_year": { "type": ["integer", "null"] },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "title", "org", "accessed"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "org": { "type": "string" },
          "accessed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "value", "unit", "status"],
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "seido_ref": { "type": "string" },
          "status": { "type": "string", "enum": ["verified", "stub"] },
          "stub_reason": { "type": "string" }
        }
      }
    },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "next_check_due": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
